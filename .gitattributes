# Normalize line endings to LF on commit, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.jsonc text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.less  text eol=lf
*.html  text eol=lf
*.htm   text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.bash  text eol=lf
*.env   text eol=lf

# Makefile requires LF (tabs are significant)
Makefile text eol=lf

# Windows scripts — keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
