{
  "name": "@e-watson/axon-pg",
  "version": "0.0.1",
  "description": "PostgreSQL toolkit for the Axon family — SQL file loader, pool, query runner, transactions",
  "keywords": [
    "postgres",
    "postgresql",
    "pg",
    "sql",
    "axon",
    "database"
  ],
  "homepage": "https://github.com/e-Watson-dot-ua/axon-pg#readme",
  "bugs": { "url": "https://github.com/e-Watson-dot-ua/axon-pg/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-Watson-dot-ua/axon-pg.git"
  },
  "license": "MIT",
  "author": {
    "name": "e-Watson",
    "url": "https://github.com/e-Watson-dot-ua"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./migrate": "./src/migrate.js"
  },
  "files": ["src"],
  "sideEffects": false,
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "start": "node src/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test \"tests/**/*.test.js\"",
    "prepublishOnly": "npm run lint && npm test"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "@e-watson/axon": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "@e-watson/axon": { "optional": true }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": ">=18.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "pg": "^8.13.0",
    "prettier": "^3.0.0"
  }
}
